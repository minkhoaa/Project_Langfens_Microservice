# Langfens Environment Variables Template
# Copy this file to a service-specific .env file (e.g., auth.env, exam.env)
# and fill in the actual values for your environment.

# ===========================
# JWT Settings (REQUIRED for all services)
# ===========================
JwtSettings__Issuer=https://your-domain.com
JwtSettings__Audience=langfens-api
JwtSettings__SignKey=CHANGE_ME_use_a_256_bit_secret_key_here

# ===========================
# Database Connection Strings
# ===========================
# Override per-service. Format: Host=...;Port=5432;Database=...;Username=...;Password=...
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=langfens;Username=postgres;Password=CHANGE_ME

# ===========================
# RabbitMQ
# ===========================
RabbitMq__Host=localhost
RabbitMq__Port=5672
RabbitMq__Username=appuser
RabbitMq__Password=CHANGE_ME
RabbitMq__VHost=/

# ===========================
# Auth Service: Google OAuth
# ===========================
Google__ClientId=CHANGE_ME
Google__ClientSecret=CHANGE_ME

# ===========================
# Writing / Speaking Service: Azure OpenAI
# ===========================
AzureOpenAI__Endpoint=https://your-resource.openai.azure.com/
AzureOpenAI__ApiKey=CHANGE_ME
AzureOpenAI__DeploymentName=gpt-4o

# ===========================
# Speaking Service: Cloudinary
# ===========================
Cloudinary__CloudName=CHANGE_ME
Cloudinary__ApiKey=CHANGE_ME
Cloudinary__ApiSecret=CHANGE_ME

# ===========================
# Chatbot Service: Ollama
# ===========================
Ollama__BaseUrl=http://ollama:11434

# ===========================
# Email Service: SMTP
# ===========================
EmailSettings__SmtpHost=smtp.gmail.com
EmailSettings__SmtpPort=587
EmailSettings__Username=CHANGE_ME
EmailSettings__Password=CHANGE_ME
EmailSettings__From=noreply@langfens.com

# ===========================
# Elasticsearch
# ===========================
ElasticSearch__Uri=http://elasticsearch:9200
